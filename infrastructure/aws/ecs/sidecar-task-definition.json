{
    "family": "data-engine-task",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
    "taskRoleArn": "${ECS_TASK_ROLE_ARN}",
    "containerDefinitions": [
        {
            "name": "ib-gateway",
            "image": "ghcr.io/gnzsnz/ib-gateway:stable",
            "portMappings": [
                {
                    "containerPort": 4001,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 4002,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 5900,
                    "protocol": "tcp"
                },
                {
                    "containerPort": 5901,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "TWS_USERID",
                    "value": "tomxiaoyzzzz"
                },
                {
                    "name": "TWS_PASSWORD",
                    "value": "19930703xyz!"
                },
                {
                    "name": "TRADING_MODE",
                    "value": "paper"
                },
                {
                    "name": "VNC_SERVER_PASSWORD",
                    "value": "password"
                },
                {
                    "name": "IBC_EXISTING_SESSION_DETECTED",
                    "value": "Relogin"
                },
                {
                    "name": "TWOFA_EXIT_INTERVAL",
                    "value": "1200"
                },
                {
                    "name": "DISPLAY",
                    "value": ":0"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/data-engine",
                    "awslogs-region": "us-west-2",
                    "awslogs-stream-prefix": "ib-gateway-sidecar"
                }
            },
            "healthCheck": {
                "command": [
                    "CMD-SHELL",
                    "netstat -an | grep 4001 || exit 1"
                ],
                "interval": 120,
                "timeout": 5,
                "retries": 10,
                "startPeriod": 300
            },
            "mountPoints": [
                {
                    "containerPath": "/root/Jts",
                    "sourceVolume": "efs-volume"
                }
            ]
        },
        {
            "name": "data-engine",
            "image": "${ECR_URI}/data-engine:latest",
            "dependsOn": [
                {
                    "containerName": "ib-gateway",
                    "condition": "START"
                }
            ],
            "portMappings": [
                {
                    "containerPort": 8080,
                    "protocol": "tcp"
                }
            ],
            "environment": [
                {
                    "name": "DATA_ENGINE__SERVER__HOST",
                    "value": "0.0.0.0"
                },
                {
                    "name": "RUST_ENV",
                    "value": "prod"
                },
                {
                    "name": "DATA_ENGINE__IBKR__ENABLED",
                    "value": "true"
                },
                {
                    "name": "DATA_ENGINE__IBKR__HOST",
                    "value": "127.0.0.1"
                },
                {
                    "name": "DATA_ENGINE__IBKR__PORT",
                    "value": "4001"
                },
                {
                    "name": "DATA_ENGINE__IBKR__CLIENT_ID",
                    "value": "1"
                },
                {
                    "name": "DATA_ENGINE__POSTGRES__HOST",
                    "value": "difyonawsstack-postgrescluster53e5bdab-5tvprzpxb3h6.cluster-c7q2668ayvaj.us-west-2.rds.amazonaws.com"
                },
                {
                    "name": "DATA_ENGINE__POSTGRES__PORT",
                    "value": "5432"
                },
                {
                    "name": "DATA_ENGINE__POSTGRES__DATABASE",
                    "value": "main"
                },
                {
                    "name": "DATA_ENGINE__POSTGRES__USERNAME",
                    "value": "postgres"
                },
                {
                    "name": "DATA_ENGINE__POSTGRES__PASSWORD",
                    "value": "u,d^MEMhVUo84xWhMC9,-GaJt=Bafw"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/data-engine",
                    "awslogs-region": "us-west-2",
                    "awslogs-stream-prefix": "data-engine-sidecar"
                }
            }
        }
    ],
    "volumes": [
        {
            "name": "efs-volume",
            "efsVolumeConfiguration": {
                "fileSystemId": "fs-00c52ad78f5fbcf0b",
                "rootDirectory": "/"
            }
        }
    ]
}