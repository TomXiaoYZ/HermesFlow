{
  "title": "HermesFlow - Data Quality",
  "uid": "hermesflow-data-quality",
  "tags": ["hermesflow", "data-quality"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
      {
        "title": "Stale Symbols",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
        "targets": [{ "expr": "data_engine_dq_stale_symbols" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            }
          }
        }
      },
      {
        "title": "Gap Symbols",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
        "targets": [{ "expr": "data_engine_dq_gap_symbols" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "title": "Price Spikes",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
        "targets": [{ "expr": "data_engine_dq_spike_symbols" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 3 },
                { "color": "red", "value": 10 }
              ]
            }
          }
        }
      },
      {
        "title": "Cross-Source Divergence",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
        "targets": [{ "expr": "data_engine_dq_cross_source_divergence" }]
      },
      {
        "title": "Low Liquidity",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
        "targets": [{ "expr": "data_engine_dq_low_liq_symbols" }]
      },
      {
        "title": "Dead Letters",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
        "targets": [{ "expr": "data_engine_dead_letter_total" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "title": "Data Quality Score by Source",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [{ "expr": "data_engine_dq_source_score", "legendFormat": "{{ source }}" }],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 0.8 }
              ]
            }
          }
        }
      },
      {
        "title": "DQ Metrics Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          { "expr": "data_engine_dq_stale_symbols", "legendFormat": "Stale" },
          { "expr": "data_engine_dq_gap_symbols", "legendFormat": "Gaps" },
          { "expr": "data_engine_dq_spike_symbols", "legendFormat": "Spikes" },
          { "expr": "data_engine_dq_cross_source_divergence", "legendFormat": "Divergence" },
          { "expr": "data_engine_dq_volume_anomaly", "legendFormat": "Volume Anomaly" },
          { "expr": "data_engine_dq_timestamp_drift_symbols", "legendFormat": "Timestamp Drift" }
        ]
      },
      {
        "title": "Volume Anomaly",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 14 },
        "targets": [{ "expr": "data_engine_dq_volume_anomaly" }]
      },
      {
        "title": "Timestamp Drift",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 14 },
        "targets": [{ "expr": "data_engine_dq_timestamp_drift_symbols" }]
      },
      {
        "title": "Validation Failure Rate",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
        "targets": [
          { "expr": "rate(data_engine_validation_failures_total[5m])", "legendFormat": "Validation Failures/s" },
          { "expr": "rate(data_engine_dead_letter_total[5m])", "legendFormat": "Dead Letters/s" }
        ]
      }
    ]
}
