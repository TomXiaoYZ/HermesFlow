{
  "title": "HermesFlow - Strategy Engine",
  "uid": "hermesflow-strategy-engine",
  "tags": ["hermesflow", "strategy"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
      {
        "title": "Active Positions",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          { "expr": "strategy_active_positions", "legendFormat": "Positions" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 10 },
                { "color": "red", "value": 50 }
              ]
            }
          }
        }
      },
      {
        "title": "Market Data Consumed",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          { "expr": "rate(strategy_market_data_consumed_total[1m]) * 60", "legendFormat": "msgs/min" }
        ]
      },
      {
        "title": "Signals Generated Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          { "expr": "rate(strategy_signals_generated_total[5m])", "legendFormat": "{{ strategy }} / {{ direction }}" }
        ]
      },
      {
        "title": "Risk Check Results",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          { "expr": "rate(strategy_risk_checks_total[5m])", "legendFormat": "{{ result }}" }
        ]
      },
      {
        "title": "Signal Generation Rate (buy vs sell)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          { "expr": "rate(strategy_signals_generated_total{direction=\"buy\"}[5m])", "legendFormat": "Buy: {{ strategy }}" },
          { "expr": "rate(strategy_signals_generated_total{direction=\"sell\"}[5m])", "legendFormat": "Sell: {{ strategy }}" }
        ]
      },
      {
        "title": "Risk Approval vs Rejection Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          { "expr": "rate(strategy_risk_checks_total{result=\"approved\"}[5m])", "legendFormat": "Approved" },
          { "expr": "rate(strategy_risk_checks_total{result=\"rejected\"}[5m])", "legendFormat": "Rejected" }
        ],
        "fieldConfig": {
          "overrides": [
            { "matcher": { "id": "byName", "options": "Approved" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "Rejected" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
          ]
        }
      },
      {
        "title": "Market Data Lag (P50 / P95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          { "expr": "histogram_quantile(0.50, rate(strategy_market_data_lag_seconds_bucket[5m]))", "legendFormat": "P50" },
          { "expr": "histogram_quantile(0.95, rate(strategy_market_data_lag_seconds_bucket[5m]))", "legendFormat": "P95" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Signal Latency (P50 / P95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          { "expr": "histogram_quantile(0.50, rate(strategy_signal_latency_seconds_bucket[5m]))", "legendFormat": "P50" },
          { "expr": "histogram_quantile(0.95, rate(strategy_signal_latency_seconds_bucket[5m]))", "legendFormat": "P95" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Market Data Consumption Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
        "targets": [
          { "expr": "rate(strategy_market_data_consumed_total[1m])", "legendFormat": "Messages/s" }
        ]
      }
    ]
}
