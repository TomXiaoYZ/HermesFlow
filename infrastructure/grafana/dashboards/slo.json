{
  "title": "HermesFlow - SLO Dashboard",
  "uid": "hermesflow-slo",
  "tags": ["hermesflow", "slo"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
      {
        "title": "SLO: Data Freshness (<30s for 99% of sources)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "1 - (count(data_engine_e2e_freshness_seconds > 30) or vector(0)) / count(data_engine_e2e_freshness_seconds)",
            "legendFormat": "Freshness SLO"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.95 },
                { "color": "green", "value": 0.99 }
              ]
            }
          }
        }
      },
      {
        "title": "SLO: Insert Success Rate (>99.9%)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "1 - (rate(data_engine_errors_total[1h]) / (rate(data_engine_messages_received_total[1h]) + 0.001))",
            "legendFormat": "Insert SLO"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.99 },
                { "color": "green", "value": 0.999 }
              ]
            }
          }
        }
      },
      {
        "title": "SLO: Quality Score (>0.8 all sources)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "min(data_engine_dq_source_score) or vector(1)",
            "legendFormat": "Min Source Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 0.8 }
              ]
            }
          }
        }
      },
      {
        "title": "SLO: E2E Latency P95 (<5s)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(data_engine_ingest_latency_seconds_bucket[1h]))",
            "legendFormat": "P95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 3 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "title": "Data Freshness Over Time (per source)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          { "expr": "data_engine_e2e_freshness_seconds", "legendFormat": "{{ source }}" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Insert Success Rate Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          {
            "expr": "1 - (rate(data_engine_errors_total[5m]) / (rate(data_engine_messages_received_total[5m]) + 0.001))",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        }
      },
      {
        "title": "Quality Score Per Source Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [
          { "expr": "data_engine_dq_source_score", "legendFormat": "{{ source }}" }
        ],
        "fieldConfig": {
          "defaults": { "min": 0, "max": 1 }
        }
      },
      {
        "title": "Ingest Latency Percentiles Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          { "expr": "histogram_quantile(0.50, rate(data_engine_ingest_latency_seconds_bucket[5m]))", "legendFormat": "P50" },
          { "expr": "histogram_quantile(0.95, rate(data_engine_ingest_latency_seconds_bucket[5m]))", "legendFormat": "P95" },
          { "expr": "histogram_quantile(0.99, rate(data_engine_ingest_latency_seconds_bucket[5m]))", "legendFormat": "P99" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Task Execution Duration",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
        "targets": [
          { "expr": "histogram_quantile(0.95, rate(data_engine_task_duration_seconds_bucket[5m]))", "legendFormat": "{{ task }}" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "title": "Task Timeouts & Overlap Skips",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
        "targets": [
          { "expr": "rate(data_engine_task_timeout_total[10m])", "legendFormat": "Timeout: {{ task }}" },
          { "expr": "rate(data_engine_task_overlap_skipped_total[10m])", "legendFormat": "Skipped: {{ task }}" }
        ]
      }
    ]
}
