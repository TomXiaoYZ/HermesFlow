package com.hermesflow.usermanagement;

import com.hermesflow.usermanagement.entity.Tenant;
import com.hermesflow.usermanagement.entity.TenantConfig;
import com.hermesflow.usermanagement.entity.User;
import com.hermesflow.usermanagement.entity.UserSession;

import java.net.InetAddress;
import java.net.UnknownHostException;
import java.time.LocalDateTime;
import java.util.UUID;

/**
 * 测试数据构建器
 * 
 * 提供便捷的方法来创建各种测试实体对象
 * 使用Builder模式，支持链式调用和默认值
 */
public class TestDataBuilder {

    /**
     * 租户构建器
     */
    public static class TenantBuilder {
        private String name = "Test Tenant";
        private String code = "test_tenant_" + System.currentTimeMillis();
        private Tenant.PlanType planType = Tenant.PlanType.BASIC;
        private Tenant.TenantStatus status = Tenant.TenantStatus.ACTIVE;
        private Integer maxUsers = 10;
        private Integer maxStrategies = 5;
        private Integer maxAssetSubscriptions = 50;
        private String description = "Test tenant description";

        public TenantBuilder name(String name) {
            this.name = name;
            return this;
        }

        public TenantBuilder code(String code) {
            this.code = code;
            return this;
        }

        public TenantBuilder planType(Tenant.PlanType planType) {
            this.planType = planType;
            return this;
        }

        public TenantBuilder status(Tenant.TenantStatus status) {
            this.status = status;
            return this;
        }

        public TenantBuilder maxUsers(Integer maxUsers) {
            this.maxUsers = maxUsers;
            return this;
        }

        public TenantBuilder maxStrategies(Integer maxStrategies) {
            this.maxStrategies = maxStrategies;
            return this;
        }

        public TenantBuilder maxAssetSubscriptions(Integer maxAssetSubscriptions) {
            this.maxAssetSubscriptions = maxAssetSubscriptions;
            return this;
        }

        public TenantBuilder description(String description) {
            this.description = description;
            return this;
        }

        public Tenant build() {
            Tenant tenant = new Tenant(name, code, planType);
            tenant.setStatus(status);
            tenant.setMaxUsers(maxUsers);
            tenant.setMaxStrategies(maxStrategies);
            tenant.setMaxAssetSubscriptions(maxAssetSubscriptions);
            tenant.setDescription(description);
            return tenant;
        }
    }

    /**
     * 用户构建器
     */
    public static class UserBuilder {
        private Tenant tenant;
        private String username = "testuser_" + System.currentTimeMillis();
        private String email = "test_" + System.currentTimeMillis() + "@hermesflow.com";
        private String passwordHash = "$2a$10$test.password.hash";
        private String firstName = "Test";
        private String lastName = "User";
        private String phone = "+1234567890";
        private User.UserStatus status = User.UserStatus.ACTIVE;
        private Boolean emailVerified = false;
        private Boolean phoneVerified = false;
        private LocalDateTime lastLoginAt;
        private LocalDateTime passwordChangedAt = LocalDateTime.now();
        private Integer failedLoginAttempts = 0;
        private LocalDateTime lockedUntil;

        public UserBuilder tenant(Tenant tenant) {
            this.tenant = tenant;
            return this;
        }

        public UserBuilder username(String username) {
            this.username = username;
            return this;
        }

        public UserBuilder email(String email) {
            this.email = email;
            return this;
        }

        public UserBuilder passwordHash(String passwordHash) {
            this.passwordHash = passwordHash;
            return this;
        }

        public UserBuilder firstName(String firstName) {
            this.firstName = firstName;
            return this;
        }

        public UserBuilder lastName(String lastName) {
            this.lastName = lastName;
            return this;
        }

        public UserBuilder phone(String phone) {
            this.phone = phone;
            return this;
        }

        public UserBuilder status(User.UserStatus status) {
            this.status = status;
            return this;
        }

        public UserBuilder emailVerified(Boolean emailVerified) {
            this.emailVerified = emailVerified;
            return this;
        }

        public UserBuilder phoneVerified(Boolean phoneVerified) {
            this.phoneVerified = phoneVerified;
            return this;
        }

        public UserBuilder lastLoginAt(LocalDateTime lastLoginAt) {
            this.lastLoginAt = lastLoginAt;
            return this;
        }

        public UserBuilder passwordChangedAt(LocalDateTime passwordChangedAt) {
            this.passwordChangedAt = passwordChangedAt;
            return this;
        }

        public UserBuilder failedLoginAttempts(Integer failedLoginAttempts) {
            this.failedLoginAttempts = failedLoginAttempts;
            return this;
        }

        public UserBuilder lockedUntil(LocalDateTime lockedUntil) {
            this.lockedUntil = lockedUntil;
            return this;
        }

        public UserBuilder locked() {
            this.status = User.UserStatus.LOCKED;
            this.lockedUntil = LocalDateTime.now().plusMinutes(15);
            this.failedLoginAttempts = 5;
            return this;
        }

        public User build() {
            if (tenant == null) {
                tenant = tenant().build();
            }
            
            User user = new User(tenant, username, email, passwordHash);
            user.setFirstName(firstName);
            user.setLastName(lastName);
            user.setPhone(phone);
            user.setStatus(status);
            user.setEmailVerified(emailVerified);
            user.setPhoneVerified(phoneVerified);
            user.setLastLoginAt(lastLoginAt);
            user.setPasswordChangedAt(passwordChangedAt);
            user.setFailedLoginAttempts(failedLoginAttempts);
            user.setLockedUntil(lockedUntil);
            return user;
        }
    }

    /**
     * 用户会话构建器
     */
    public static class UserSessionBuilder {
        private User user;
        private String sessionToken = "session_" + UUID.randomUUID().toString();
        private String refreshToken = "refresh_" + UUID.randomUUID().toString();
        private InetAddress ipAddress;
        private String userAgent = "Test User Agent";
        private LocalDateTime expiresAt = LocalDateTime.now().plusHours(1);
        private Boolean isActive = true;
        private LocalDateTime lastActivityAt = LocalDateTime.now();

        public UserSessionBuilder() {
            try {
                this.ipAddress = InetAddress.getByName("127.0.0.1");
            } catch (UnknownHostException e) {
                // 忽略异常，使用null
            }
        }

        public UserSessionBuilder user(User user) {
            this.user = user;
            return this;
        }

        public UserSessionBuilder sessionToken(String sessionToken) {
            this.sessionToken = sessionToken;
            return this;
        }

        public UserSessionBuilder refreshToken(String refreshToken) {
            this.refreshToken = refreshToken;
            return this;
        }

        public UserSessionBuilder ipAddress(String ipAddress) {
            try {
                this.ipAddress = InetAddress.getByName(ipAddress);
            } catch (UnknownHostException e) {
                throw new RuntimeException("Invalid IP address: " + ipAddress, e);
            }
            return this;
        }

        public UserSessionBuilder userAgent(String userAgent) {
            this.userAgent = userAgent;
            return this;
        }

        public UserSessionBuilder expiresAt(LocalDateTime expiresAt) {
            this.expiresAt = expiresAt;
            return this;
        }

        public UserSessionBuilder isActive(Boolean isActive) {
            this.isActive = isActive;
            return this;
        }

        public UserSessionBuilder lastActivityAt(LocalDateTime lastActivityAt) {
            this.lastActivityAt = lastActivityAt;
            return this;
        }

        public UserSessionBuilder expired() {
            this.expiresAt = LocalDateTime.now().minusHours(1);
            return this;
        }

        public UserSessionBuilder inactive() {
            this.isActive = false;
            return this;
        }

        public UserSession build() {
            if (user == null) {
                user = user().build();
            }
            
            UserSession session = new UserSession(user, sessionToken, refreshToken, expiresAt);
            session.setIpAddress(ipAddress);
            session.setUserAgent(userAgent);
            session.setIsActive(isActive);
            session.setLastActivityAt(lastActivityAt);
            return session;
        }
    }

    /**
     * 租户配置构建器
     */
    public static class TenantConfigBuilder {
        private Tenant tenant;
        private String configKey = "test.config.key";
        private String configValue = "test config value";
        private String configType = "string";
        private Boolean isEncrypted = false;
        private String description = "Test configuration";

        public TenantConfigBuilder tenant(Tenant tenant) {
            this.tenant = tenant;
            return this;
        }

        public TenantConfigBuilder configKey(String configKey) {
            this.configKey = configKey;
            return this;
        }

        public TenantConfigBuilder configValue(String configValue) {
            this.configValue = configValue;
            return this;
        }

        public TenantConfigBuilder configType(String configType) {
            this.configType = configType;
            return this;
        }

        public TenantConfigBuilder isEncrypted(Boolean isEncrypted) {
            this.isEncrypted = isEncrypted;
            return this;
        }

        public TenantConfigBuilder description(String description) {
            this.description = description;
            return this;
        }

        public TenantConfigBuilder integerConfig(String key, Integer value) {
            this.configKey = key;
            this.configValue = value.toString();
            this.configType = "integer";
            return this;
        }

        public TenantConfigBuilder booleanConfig(String key, Boolean value) {
            this.configKey = key;
            this.configValue = value.toString();
            this.configType = "boolean";
            return this;
        }

        public TenantConfigBuilder encryptedConfig(String key, String value) {
            this.configKey = key;
            this.configValue = value;
            this.isEncrypted = true;
            return this;
        }

        public TenantConfig build() {
            if (tenant == null) {
                tenant = tenant().build();
            }
            
            TenantConfig config = new TenantConfig(tenant, configKey, configValue, configType);
            config.setIsEncrypted(isEncrypted);
            config.setDescription(description);
            return config;
        }
    }

    // 静态工厂方法
    public static TenantBuilder tenant() {
        return new TenantBuilder();
    }

    public static UserBuilder user() {
        return new UserBuilder();
    }

    public static UserSessionBuilder userSession() {
        return new UserSessionBuilder();
    }

    public static TenantConfigBuilder tenantConfig() {
        return new TenantConfigBuilder();
    }

    // 便捷方法
    public static Tenant defaultTenant() {
        return tenant().build();
    }

    public static User defaultUser() {
        return user().build();
    }

    public static UserSession defaultUserSession() {
        return userSession().build();
    }

    public static TenantConfig defaultTenantConfig() {
        return tenantConfig().build();
    }

    public static Tenant enterpriseTenant() {
        return tenant()
            .name("Enterprise Tenant")
            .code("enterprise_tenant")
            .planType(Tenant.PlanType.ENTERPRISE)
            .maxUsers(200)
            .maxStrategies(100)
            .maxAssetSubscriptions(1000)
            .build();
    }

    public static User adminUser() {
        return user()
            .username("admin")
            .email("admin@hermesflow.com")
            .firstName("Admin")
            .lastName("User")
            .emailVerified(true)
            .build();
    }

    public static User lockedUser() {
        return user()
            .locked()
            .build();
    }
} 