package com.hermesflow.usermanagement;

import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.context.ApplicationContext;
import org.springframework.core.env.Environment;
import org.springframework.test.context.ActiveProfiles;

import jakarta.validation.Validator;

import static org.assertj.core.api.Assertions.*;

/**
 * UserManagementApplication单元测试
 * 
 * 测试Spring Boot应用程序的启动和配置，包括：
 * - 应用程序上下文加载
 * - Bean创建和依赖注入
 * - 配置属性加载
 * - 环境配置验证
 * - 数据库连接测试
 */
@SpringBootTest
@ActiveProfiles("test")
@DisplayName("UserManagementApplication测试")
class UserManagementApplicationTest extends BaseTest {

    @Autowired
    private ApplicationContext applicationContext;

    @Autowired
    private Environment environment;

    @Nested
    @DisplayName("应用程序上下文测试")
    class ApplicationContextTests {

        @Test
        @DisplayName("应用程序上下文应该成功加载")
        void applicationContext_ShouldLoadSuccessfully() {
            // When & Then
            assertThat(applicationContext).isNotNull();
            assertThat(applicationContext.getId()).isNotNull();
            assertThat(applicationContext.getDisplayName()).contains("UserManagementApplication");
        }

        @Test
        @DisplayName("应用程序应该在测试环境中运行")
        void application_ShouldRunInTestEnvironment() {
            // When & Then
            assertThat(environment.getActiveProfiles()).contains("test");
            assertThat(environment.getProperty("spring.application.name"))
                .isEqualTo("user-management-service-test");
        }

        @Test
        @DisplayName("应用程序上下文应该包含所有必需的Bean")
        void applicationContext_ShouldContainRequiredBeans() {
            // When & Then
            assertThat(applicationContext.containsBean("userManagementApplication")).isTrue();
            
            // Validation beans
            assertThat(applicationContext.getBean(Validator.class)).isNotNull();
            
            // Check if health controller is loaded
            assertThat(applicationContext.containsBean("healthController")).isTrue();
        }
    }

    @Nested
    @DisplayName("配置属性测试")
    class ConfigurationPropertiesTests {

        @Test
        @DisplayName("数据库配置应该正确加载")
        void databaseConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("spring.datasource.url"))
                .contains("jdbc:h2:mem:testdb");
            assertThat(environment.getProperty("spring.datasource.username"))
                .isEqualTo("sa");
            assertThat(environment.getProperty("spring.jpa.hibernate.ddl-auto"))
                .isEqualTo("create-drop");
        }

        @Test
        @DisplayName("Redis配置应该正确加载")
        void redisConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("spring.data.redis.host"))
                .isEqualTo("localhost");
            assertThat(environment.getProperty("spring.data.redis.port"))
                .isEqualTo("6370");
        }

        @Test
        @DisplayName("安全配置应该正确加载")
        void securityConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.security.admin.username"))
                .isEqualTo("admin");
            assertThat(environment.getProperty("hermesflow.security.admin.password"))
                .isNotBlank();
        }

        @Test
        @DisplayName("JWT配置应该正确加载")
        void jwtConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.jwt.secret"))
                .isNotBlank();
            assertThat(environment.getProperty("hermesflow.jwt.access-token-expiration"))
                .isEqualTo("900"); // 15 minutes
            assertThat(environment.getProperty("hermesflow.jwt.refresh-token-expiration"))
                .isEqualTo("3600"); // 1 hour
        }

        @Test
        @DisplayName("多租户配置应该正确加载")
        void multiTenantConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.multi-tenant.enabled"))
                .isEqualTo("true");
            assertThat(environment.getProperty("hermesflow.multi-tenant.default-tenant"))
                .isEqualTo("default");
        }

        @Test
        @DisplayName("密码策略配置应该正确加载")
        void passwordPolicyConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.password-policy.min-length"))
                .isEqualTo("8");
            assertThat(environment.getProperty("hermesflow.password-policy.require-uppercase"))
                .isEqualTo("true");
            assertThat(environment.getProperty("hermesflow.password-policy.require-lowercase"))
                .isEqualTo("true");
            assertThat(environment.getProperty("hermesflow.password-policy.require-numbers"))
                .isEqualTo("true");
            assertThat(environment.getProperty("hermesflow.password-policy.require-special-chars"))
                .isEqualTo("true");
        }
    }

    @Nested
    @DisplayName("Bean配置测试")
    class BeanConfigurationTests {

        @Test
        @DisplayName("验证器Bean应该正确配置")
        void validatorBean_ShouldBeConfiguredCorrectly() {
            // When
            Validator validator = applicationContext.getBean(Validator.class);

            // Then
            assertThat(validator).isNotNull();
            assertThat(validator.getClass().getName())
                .contains("ValidatorImpl");
        }

        @Test
        @DisplayName("应该能够获取所有控制器Bean")
        void shouldBeAbleToGetAllControllerBeans() {
            // When & Then
            assertThatCode(() -> {
                applicationContext.getBean("healthController");
            }).doesNotThrowAnyException();
        }
    }

    @Nested
    @DisplayName("环境配置测试")
    class EnvironmentConfigurationTests {

        @Test
        @DisplayName("测试环境应该禁用某些功能")
        void testEnvironment_ShouldDisableCertainFeatures() {
            // When & Then
            // API documentation should be disabled in test
            assertThat(environment.getProperty("springdoc.api-docs.enabled"))
                .isEqualTo("false");
            assertThat(environment.getProperty("springdoc.swagger-ui.enabled"))
                .isEqualTo("false");
        }

        @Test
        @DisplayName("测试环境应该启用SQL日志")
        void testEnvironment_ShouldEnableSqlLogging() {
            // When & Then
            assertThat(environment.getProperty("spring.jpa.show-sql"))
                .isEqualTo("true");
            assertThat(environment.getProperty("spring.jpa.properties.hibernate.format_sql"))
                .isEqualTo("true");
        }

        @Test
        @DisplayName("测试环境应该启用H2控制台")
        void testEnvironment_ShouldEnableH2Console() {
            // When & Then
            assertThat(environment.getProperty("spring.h2.console.enabled"))
                .isEqualTo("true");
        }

        @Test
        @DisplayName("日志级别应该正确配置")
        void loggingLevels_ShouldBeConfiguredCorrectly() {
            // When & Then
            assertThat(environment.getProperty("logging.level.com.hermesflow"))
                .isEqualTo("DEBUG");
            assertThat(environment.getProperty("logging.level.org.springframework.security"))
                .isEqualTo("DEBUG");
            assertThat(environment.getProperty("logging.level.org.hibernate.SQL"))
                .isEqualTo("DEBUG");
        }
    }

    @Nested
    @DisplayName("应用程序属性测试")
    class ApplicationPropertiesTests {

        @Test
        @DisplayName("应用程序名称应该正确设置")
        void applicationName_ShouldBeSetCorrectly() {
            // When & Then
            assertThat(environment.getProperty("spring.application.name"))
                .isEqualTo("user-management-service-test");
        }

        @Test
        @DisplayName("服务器端口应该正确设置")
        void serverPort_ShouldBeSetCorrectly() {
            // When & Then
            String port = environment.getProperty("server.port");
            if (port != null) {
                assertThat(Integer.parseInt(port)).isPositive();
            }
        }

        @Test
        @DisplayName("管理端点应该正确配置")
        void managementEndpoints_ShouldBeConfiguredCorrectly() {
            // When & Then
            assertThat(environment.getProperty("management.endpoints.web.exposure.include"))
                .contains("health");
        }
    }

    @Nested
    @DisplayName("数据库连接测试")
    class DatabaseConnectionTests {

        @Test
        @DisplayName("应该能够连接到测试数据库")
        void shouldBeAbleToConnectToTestDatabase() {
            // This test verifies that the application can start with database connectivity
            // The fact that the Spring context loads successfully indicates database connection is working
            
            // When & Then
            assertThat(environment.getProperty("spring.datasource.url"))
                .isNotNull()
                .contains("h2");
        }

        @Test
        @DisplayName("JPA配置应该正确")
        void jpaConfiguration_ShouldBeCorrect() {
            // When & Then
            assertThat(environment.getProperty("spring.jpa.hibernate.ddl-auto"))
                .isEqualTo("create-drop");
            assertThat(environment.getProperty("spring.jpa.database-platform"))
                .contains("H2");
        }
    }

    @Nested
    @DisplayName("安全配置测试")
    class SecurityConfigurationTests {

        @Test
        @DisplayName("安全配置应该正确加载")
        void securityConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.security.admin.username"))
                .isNotBlank();
            assertThat(environment.getProperty("hermesflow.security.admin.password"))
                .isNotBlank();
        }

        @Test
        @DisplayName("JWT密钥应该正确配置")
        void jwtSecret_ShouldBeConfiguredCorrectly() {
            // When & Then
            String jwtSecret = environment.getProperty("hermesflow.jwt.secret");
            assertThat(jwtSecret)
                .isNotBlank()
                .hasSizeGreaterThanOrEqualTo(32); // Minimum recommended length for JWT secret
        }
    }

    @Nested
    @DisplayName("监控配置测试")
    class MonitoringConfigurationTests {

        @Test
        @DisplayName("监控配置应该正确加载")
        void monitoringConfiguration_ShouldLoadCorrectly() {
            // When & Then
            assertThat(environment.getProperty("hermesflow.monitoring.metrics.enabled"))
                .isEqualTo("true");
            assertThat(environment.getProperty("hermesflow.monitoring.health-check.enabled"))
                .isEqualTo("true");
        }

        @Test
        @DisplayName("健康检查间隔应该正确配置")
        void healthCheckInterval_ShouldBeConfiguredCorrectly() {
            // When & Then
            String interval = environment.getProperty("hermesflow.monitoring.health-check.interval");
            if (interval != null) {
                assertThat(interval).matches("\\d+[smh]"); // Should be in format like "30s", "5m", "1h"
            }
        }
    }

    @Nested
    @DisplayName("应用程序启动测试")
    class ApplicationStartupTests {

        @Test
        @DisplayName("应用程序应该成功启动")
        void application_ShouldStartSuccessfully() {
            // When & Then
            // The fact that this test runs means the application started successfully
            assertThat(applicationContext.isActive()).isTrue();
            assertThat(applicationContext.isRunning()).isTrue();
        }

        @Test
        @DisplayName("应用程序应该在合理时间内启动")
        void application_ShouldStartWithinReasonableTime() {
            // When & Then
            // This is more of a performance test - if the context loads, startup time was reasonable
            assertThat(applicationContext.getStartupDate()).isPositive();
        }

        @Test
        @DisplayName("应用程序应该正确处理配置文件")
        void application_ShouldHandleConfigurationFilesCorrectly() {
            // When & Then
            assertThat(environment.getActiveProfiles()).isNotEmpty();
            assertThat(environment.getProperty("spring.config.name")).isNotNull();
        }
    }

    @Nested
    @DisplayName("Bean生命周期测试")
    class BeanLifecycleTests {

        @Test
        @DisplayName("所有Bean应该正确初始化")
        void allBeans_ShouldInitializeCorrectly() {
            // When & Then
            String[] beanNames = applicationContext.getBeanDefinitionNames();
            assertThat(beanNames).isNotEmpty();
            
            // Verify some key beans exist
            assertThat(beanNames).contains("userManagementApplication");
            
            // Verify no beans failed to initialize (if they did, context wouldn't load)
            for (String beanName : beanNames) {
                assertThatCode(() -> applicationContext.getBean(beanName))
                    .doesNotThrowAnyException();
            }
        }

        @Test
        @DisplayName("Bean依赖关系应该正确解析")
        void beanDependencies_ShouldResolveCorrectly() {
            // When & Then
            // If the application context loads successfully, all dependencies are resolved
            assertThat(applicationContext.getBeanDefinitionCount()).isPositive();
        }
    }

    @Nested
    @DisplayName("配置验证测试")
    class ConfigurationValidationTests {

        @Test
        @DisplayName("必需的配置属性应该存在")
        void requiredConfigurationProperties_ShouldExist() {
            // When & Then
            assertThat(environment.getProperty("spring.application.name")).isNotBlank();
            assertThat(environment.getProperty("spring.datasource.url")).isNotBlank();
            assertThat(environment.getProperty("hermesflow.jwt.secret")).isNotBlank();
        }

        @Test
        @DisplayName("配置属性应该有有效值")
        void configurationProperties_ShouldHaveValidValues() {
            // When & Then
            String minPasswordLength = environment.getProperty("hermesflow.password-policy.min-length");
            if (minPasswordLength != null) {
                assertThat(Integer.parseInt(minPasswordLength)).isGreaterThan(0);
            }
            
            String accessTokenExpiration = environment.getProperty("hermesflow.jwt.access-token-expiration");
            if (accessTokenExpiration != null) {
                assertThat(Integer.parseInt(accessTokenExpiration)).isPositive();
            }
        }
    }
} 