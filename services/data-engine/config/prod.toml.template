# Production Configuration Template for Data Engine
# Copy this file to prod.toml and fill in your credentials

[server]
host = "0.0.0.0"
port = 8080
shutdown_timeout_secs = 30

[redis]
# AWS ElastiCache Valkey (Redis-compatible) with TLS
url = "rediss://:YOUR_REDIS_PASSWORD@YOUR_REDIS_ENDPOINT:6379"
pool_size = 20
ttl_secs = 86400

[postgres]
host = "YOUR_POSTGRES_HOST"
port = 5432
database = "main"
username = "postgres"
password = "YOUR_POSTGRES_PASSWORD"
max_connections = 20

[clickhouse]
# Optional: Only if you need high-frequency market tick data
url = "http://your-clickhouse-host:8123"
database = "hermesflow"
username = "default"
password = ""
batch_size = 5000
flush_interval_ms = 3000

[performance]
channel_buffer_size = 50000
max_reconnect_attempts = 10
reconnect_delay_secs = 5
health_check_interval_secs = 30

[logging]
level = "info"
format = "json"
output = "stdout"

# Twitter Configuration (Optional)
# Uncomment and fill in if you want to enable Twitter scraping
# [twitter]
# username = "YOUR_TWITTER_USERNAME"
