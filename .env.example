# 数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hermesflow
POSTGRES_PASSWORD=hermesflow
POSTGRES_DB=hermesflow

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# 消息队列配置
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=hermesflow

# 日志配置
LOG_LEVEL=INFO
ELASTICSEARCH_URL=http://localhost:9200

# 交易所 API 配置
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase

BITGET_API_KEY=your_bitget_api_key
BITGET_API_SECRET=your_bitget_api_secret

# Web3 配置
ETH_RPC_URL=https://mainnet.infura.io/v3/your_project_id
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com

# 安全配置
JWT_SECRET=your_jwt_secret
API_KEY_ENCRYPTION_KEY=your_encryption_key

# 服务端口配置
DATA_SERVICE_PORT=8000
TRADING_ENGINE_PORT=8001
STRATEGY_ENGINE_PORT=8002
RISK_CONTROL_PORT=8003
EXECUTION_SERVICE_PORT=8004
ACCOUNT_SERVICE_PORT=8005
SECURITY_SERVICE_PORT=8006
REPORT_SERVICE_PORT=8007
WEB_UI_PORT=3000

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Slack 通知配置
SLACK_WEBHOOK_URL=your_slack_webhook_url
SLACK_CHANNEL=#trading-alerts

# 其他配置
ENVIRONMENT=local  # local, dev, prod 