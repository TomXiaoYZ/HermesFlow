# HermesFlow Environment Configuration
# Copy to .env and fill in real values: cp .env.example .env

# ── Database ───────────────────────────────────────────
POSTGRES_PASSWORD=password
CLICKHOUSE_PASSWORD=hermesflow
REDIS_URL=redis://localhost:6379

# ── Data Engine API Keys ──────────────────────────────
DATA_ENGINE__BIRDEYE__API_KEY=your_birdeye_api_key
DATA_ENGINE__HELIUS__API_KEY=your_helius_api_key

# ── Polygon.io (US Stocks) ────────────────────────────
POLYGON_API_KEY=your_polygon_api_key
POLYGON_ENABLED=true
POLYGON_WS_ENABLED=false
POLYGON_RATE_LIMIT=5

# ── IBKR Dual-Gateway ─────────────────────────────────
TWS_USERID=your_ibkr_username
TWS_PASSWORD=your_ibkr_password
TRADING_MODE=paper
TWS_USERID_LS=your_ibkr_username_ls
TWS_PASSWORD_LS=your_ibkr_password_ls
IBKR_HOST=ib-gateway
IBKR_PORT=4004
IBKR_HOST_LS=ib-gateway-ls
IBKR_PORT_LS=4004
IBKR_ACCOUNT_LONG_ONLY=your_account_id
IBKR_ACCOUNT_LONG_SHORT=your_account_id
IBKR_CLIENT_ID_LONG_ONLY=1
IBKR_CLIENT_ID_LONG_SHORT=1

# ── AWS (Bedrock LLM Oracle) ──────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ── Discord Alerts ────────────────────────────────────
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# ── Grafana (optional) ────────────────────────────────
GRAFANA_ADMIN_PASSWORD=hermesflow

# ── JWT ──────────────────────────────────────────────
# Base64-encoded HMAC key shared between gateway and user-management
# Must match the jwt.secret property in user-management
JWT_SECRET=NE4zNTI2NjU1NkE1ODZFMzI3MjM1NzUzODc4MkY0MTNGNDQyODQ3MkI0QjYyNTA2NDUzNjc1NjZCNTk3MA==

# ── Application ───────────────────────────────────────
RUST_LOG=info
ADMIN_INITIAL_PASSWORD=admin
