#!/usr/bin/env bash
# pre-commit hook: Prevent committing secrets, credentials, and sensitive data.
# Scans staged files for patterns that indicate hardcoded secrets.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get staged files (only added/modified, skip deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

FOUND_SECRETS=0

# ---------- Pattern definitions ----------
# Each pattern: "LABEL:::REGEX"
# Regex is extended (grep -E). Scans staged file content only.

PATTERNS=(
    # Private keys
    "RSA/SSH Private Key:::-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----"
    "PGP Private Key:::-----BEGIN PGP PRIVATE KEY BLOCK-----"

    # AWS credentials
    "AWS Access Key ID:::AKIA[0-9A-Z]{16}"
    "AWS Secret Access Key:::['\"]?aws_secret_access_key['\"]?\s*[:=]\s*['\"][A-Za-z0-9/+=]{40}['\"]"

    # Generic high-entropy secrets assigned to variables
    "Hardcoded Password:::(password|passwd|pwd)\s*[:=]\s*['\"][^'\"]{8,}['\"]"
    "Hardcoded Secret:::(secret|secret_key|SECRET_KEY)\s*[:=]\s*['\"][^'\"]{8,}['\"]"
    "Hardcoded Token:::(token|auth_token|access_token|bearer)\s*[:=]\s*['\"][A-Za-z0-9_\-\.]{20,}['\"]"
    "Hardcoded API Key:::(api_key|apikey|api-key|API_KEY)\s*[:=]\s*['\"][A-Za-z0-9_\-]{16,}['\"]"

    # Solana private key (Base58, 64-88 chars)
    "Solana Private Key:::SOLANA_PRIVATE_KEY\s*[:=]\s*['\"][1-9A-HJ-NP-Za-km-z]{44,88}['\"]"

    # Connection strings with embedded passwords
    "DB Connection String with Password:::postgres(ql)?://[^:]+:[^@]{4,}@"
    "Redis Connection with Password:::redis://:[^@]{4,}@"

    # GitHub/GitLab tokens
    "GitHub Token:::gh[pousr]_[A-Za-z0-9_]{36,}"
    "GitLab Token:::glpat-[A-Za-z0-9\-]{20,}"

    # Slack/Discord tokens
    "Slack Token:::xox[baprs]-[0-9]{10,13}-[A-Za-z0-9]+"
    "Discord Webhook:::discord(app)?\.com/api/webhooks/[0-9]+/[A-Za-z0-9_\-]+"

    # JWT with actual payload (not variable references)
    "Hardcoded JWT:::eyJ[A-Za-z0-9_-]{10,}\.eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_\-]+"

    # .env file content accidentally staged
    "Env File Secrets:::^[A-Z_]+(PASSWORD|SECRET|KEY|TOKEN)\s*=\s*[^\$\{][^\s]+"
)

# ---------- File extension allowlist for binary skip ----------
SKIP_EXTENSIONS="(png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|zip|tar|gz|lock|sum)$"

# ---------- Scanning ----------
for file in $STAGED_FILES; do
    # Skip binary files and lock files
    if echo "$file" | grep -qiE "$SKIP_EXTENSIONS"; then
        continue
    fi

    # Skip .env.example files (they should have placeholder values)
    if echo "$file" | grep -qE '\.env\..*example$'; then
        continue
    fi

    # Skip this hook file itself
    if [ "$file" = ".git/hooks/pre-commit" ]; then
        continue
    fi

    # Get staged content (not working tree content)
    CONTENT=$(git show ":$file" 2>/dev/null || true)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    for pattern_entry in "${PATTERNS[@]}"; do
        LABEL="${pattern_entry%%:::*}"
        REGEX="${pattern_entry##*:::}"

        # Search in staged content
        MATCHES=$(echo "$CONTENT" | grep -nE "$REGEX" 2>/dev/null || true)

        if [ -n "$MATCHES" ]; then
            # Filter out false positives: comments, env var references, placeholder values
            FILTERED=$(echo "$MATCHES" | grep -vE \
                '(#.*|//.*|/\*.*|\*.*|<!--.*|^\s*$)' | grep -vE \
                '(\$\{|\$\(|env::|getenv|os\.getenv|env::var|process\.env|System\.getenv)' | grep -vE \
                '(placeholder|example|CHANGEME|TODO|FIXME|xxx|your[_-]|dummy|test123|password123|default)' | grep -vE \
                '(\.env\.example|\.sample|template)' || true)

            if [ -n "$FILTERED" ]; then
                if [ $FOUND_SECRETS -eq 0 ]; then
                    echo -e "${RED}===== SECRET DETECTION: COMMIT BLOCKED =====${NC}"
                    echo ""
                fi
                FOUND_SECRETS=$((FOUND_SECRETS + 1))
                echo -e "${RED}[$LABEL]${NC} in ${YELLOW}$file${NC}:"
                echo "$FILTERED" | head -3 | while IFS= read -r line; do
                    # Mask the actual secret value in output
                    echo "  Line $line" | sed -E 's/([=:]\s*['\''"]?).{8,}/\1********/g'
                done
                echo ""
            fi
        fi
    done
done

if [ $FOUND_SECRETS -gt 0 ]; then
    echo -e "${RED}Found $FOUND_SECRETS potential secret(s) in staged files.${NC}"
    echo ""
    echo "Options:"
    echo "  1. Remove the secret and use environment variables instead"
    echo "  2. If this is a false positive, use: git commit --no-verify"
    echo ""
    exit 1
fi

exit 0
