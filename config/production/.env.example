# 数据库配置
DB_HOST=postgres.hermesflow.svc
DB_PORT=5432
DB_USER=hermesflow
DB_PASSWORD=
DB_NAME=hermesflow_prod

# Redis配置
REDIS_HOST=redis.hermesflow.svc
REDIS_PORT=6379
REDIS_PASSWORD=

# ClickHouse配置
CLICKHOUSE_HOST=clickhouse.hermesflow.svc
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=hermesflow

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=kafka.hermesflow.svc:9092
KAFKA_CONSUMER_GROUP=hermesflow

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 监控配置
PROMETHEUS_PUSHGATEWAY=http://prometheus.monitoring.svc:9091

# Binance API配置
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# OKX API配置
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_TESTNET=false

# Bitget API配置
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=false

# 系统配置
MAX_WORKERS=8
RETRY_ATTEMPTS=5
RETRY_DELAY=2.0
REQUEST_TIMEOUT=10.0
WEBSOCKET_TIMEOUT=30.0

# 风控配置
MAX_POSITION_SIZE=0.5
MAX_LEVERAGE=2.0
MIN_MARGIN_RATIO=0.15
MAX_DRAWDOWN=0.15
MAX_DAILY_LOSS=0.05 