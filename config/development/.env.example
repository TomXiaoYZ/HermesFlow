# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_USER=hermesflow
DB_PASSWORD=hermesflow
DB_NAME=hermesflow_dev

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ClickHouse配置
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=hermesflow

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=hermesflow

# 日志配置
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# 监控配置
PROMETHEUS_PUSHGATEWAY=http://prometheus:9091

# Binance API配置
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
BINANCE_TESTNET=true

# OKX API配置
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase
OKX_TESTNET=true

# Bitget API配置
BITGET_API_KEY=your_bitget_api_key
BITGET_API_SECRET=your_bitget_api_secret
BITGET_PASSPHRASE=your_bitget_passphrase
BITGET_TESTNET=true

# 系统配置
MAX_WORKERS=4
RETRY_ATTEMPTS=3
RETRY_DELAY=1.0
REQUEST_TIMEOUT=30.0
WEBSOCKET_TIMEOUT=60.0

# 风控配置
MAX_POSITION_SIZE=1.0
MAX_LEVERAGE=3.0
MIN_MARGIN_RATIO=0.1
MAX_DRAWDOWN=0.2
MAX_DAILY_LOSS=0.1 