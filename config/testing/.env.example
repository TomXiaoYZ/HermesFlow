# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_USER=hermesflow_test
DB_PASSWORD=hermesflow_test
DB_NAME=hermesflow_test

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ClickHouse配置
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=hermesflow_test

# Kafka配置
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=hermesflow_test

# 日志配置
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# 监控配置
PROMETHEUS_PUSHGATEWAY=http://prometheus:9091

# Binance API配置
BINANCE_API_KEY=test_key
BINANCE_API_SECRET=test_secret
BINANCE_TESTNET=true

# OKX API配置
OKX_API_KEY=test_key
OKX_API_SECRET=test_secret
OKX_PASSPHRASE=test_passphrase
OKX_TESTNET=true

# Bitget API配置
BITGET_API_KEY=test_key
BITGET_API_SECRET=test_secret
BITGET_PASSPHRASE=test_passphrase
BITGET_TESTNET=true

# 系统配置
MAX_WORKERS=2
RETRY_ATTEMPTS=2
RETRY_DELAY=0.5
REQUEST_TIMEOUT=5.0
WEBSOCKET_TIMEOUT=10.0

# 风控配置
MAX_POSITION_SIZE=1.0
MAX_LEVERAGE=5.0
MIN_MARGIN_RATIO=0.05
MAX_DRAWDOWN=0.3
MAX_DAILY_LOSS=0.2 